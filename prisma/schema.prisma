// BrokerOS — Prisma schema
// Per house rules: no prisma.config.ts, enums referenced via generated types only.

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}

// ─── Auth ──────────────────────────────────────────────────────────

enum UserRole {
  OWNER
  BROKER
  ANALYST
}

model User {
  id            String    @id @default(cuid())
  email         String    @unique
  name          String?
  passwordHash  String?
  role          UserRole  @default(BROKER)
  emailVerified DateTime?
  image         String?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  accounts Account[]
  sessions Session[]
  interactions Interaction[]
  workflows    Workflow[]

  @@index([email])
}

model Account {
  id                String  @id @default(cuid())
  userId            String
  type              String
  provider          String
  providerAccountId String
  refresh_token     String?
  access_token      String?
  expires_at        Int?
  token_type        String?
  scope             String?
  id_token          String?
  session_state     String?

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerAccountId])
}

model Session {
  id           String   @id @default(cuid())
  sessionToken String   @unique
  userId       String
  expires      DateTime
  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model VerificationToken {
  identifier String
  token      String   @unique
  expires    DateTime

  @@unique([identifier, token])
}

// ─── Lead domain ───────────────────────────────────────────────────

enum LeadStatus {
  NEW
  CONTACTED
  QUALIFIED
  IN_APPLICATION
  CLOSED
  LOST
}

enum CreditScoreRange {
  UNDER_600
  SCORE_600_649
  SCORE_650_699
  SCORE_700_749
  SCORE_750_PLUS
  UNKNOWN
}

enum LoanProduct {
  SBA
  MCA
  EQUIPMENT
  WORKING_CAPITAL
  LINE_OF_CREDIT
  OTHER
}

model Lead {
  id                    String            @id @default(cuid())
  // Borrower
  businessName          String
  ownerName             String
  email                 String
  phone                 String
  // Loan request
  loanAmount            Int               // USD, whole dollars
  monthlyRevenue        Int               // USD, whole dollars
  timeInBusinessMonths  Int
  industry              String
  loanPurpose           String
  creditScoreRange      CreditScoreRange  @default(UNKNOWN)
  product               LoanProduct       @default(WORKING_CAPITAL)
  // Scoring
  score                 Int?              // 0-100
  scoreReason           String?           @db.Text
  scoredAt              DateTime?
  // Pipeline
  status                LeadStatus        @default(NEW)
  source                String?           // 'form', 'referral', 'import', ...
  assignedToId          String?
  // Meta
  notes                 String?           @db.Text
  metadata              Json?

  createdAt             DateTime          @default(now())
  updatedAt             DateTime          @updatedAt

  application   Application?
  documents     Document[]
  interactions  Interaction[]
  workflowRuns  WorkflowRun[]

  @@index([status])
  @@index([score])
  @@index([createdAt])
  @@index([email])
}

// ─── Application + documents ───────────────────────────────────────

enum ApplicationStage {
  SUBMITTED
  DOCS_REQUESTED
  DOCS_RECEIVED
  UNDERWRITING
  LENDER_MATCHED
  APPROVED
  FUNDED
  DECLINED
}

model Application {
  id            String            @id @default(cuid())
  leadId        String            @unique
  stage         ApplicationStage  @default(SUBMITTED)
  lenderMatch   String?
  fundedAmount  Int?
  commissionBps Int?              // basis points
  notes         String?           @db.Text

  createdAt     DateTime          @default(now())
  updatedAt     DateTime          @updatedAt

  lead Lead @relation(fields: [leadId], references: [id], onDelete: Cascade)

  @@index([stage])
}

enum DocumentType {
  BANK_STATEMENT
  TAX_RETURN
  DRIVERS_LICENSE
  VOIDED_CHECK
  PROFIT_LOSS
  BALANCE_SHEET
  OTHER
}

model Document {
  id            String        @id @default(cuid())
  leadId        String
  type          DocumentType
  url           String
  filename      String
  sizeBytes     Int?
  ocrExtracted  Json?

  uploadedAt    DateTime      @default(now())

  lead Lead @relation(fields: [leadId], references: [id], onDelete: Cascade)

  @@index([leadId])
}

// ─── Interactions (timeline) ───────────────────────────────────────

enum InteractionType {
  EMAIL
  SMS
  CALL
  NOTE
  STATUS_CHANGE
  AI_ACTION
}

enum InteractionDirection {
  INBOUND
  OUTBOUND
  INTERNAL
}

model Interaction {
  id         String                @id @default(cuid())
  leadId     String
  userId     String?
  type       InteractionType
  direction  InteractionDirection  @default(INTERNAL)
  subject    String?
  content    String                @db.Text
  outcome    String?
  metadata   Json?

  createdAt  DateTime              @default(now())

  lead Lead  @relation(fields: [leadId], references: [id], onDelete: Cascade)
  user User? @relation(fields: [userId], references: [id], onDelete: SetNull)

  @@index([leadId, createdAt])
}

// ─── Email templates ───────────────────────────────────────────────

enum EmailTrigger {
  LEAD_HIGH_SCORE
  LEAD_DOCS_REQUEST
  LEAD_FOLLOWUP
  LEAD_APPROVED
  LEAD_DECLINED
  MANUAL
}

model EmailTemplate {
  id         String        @id @default(cuid())
  name       String
  subject    String
  body       String        @db.Text
  trigger    EmailTrigger  @default(MANUAL)
  enabled    Boolean       @default(true)

  createdAt  DateTime      @default(now())
  updatedAt  DateTime      @updatedAt

  @@index([trigger])
}

// ─── Scoring config (single row, admin-tunable) ────────────────────

model ScoringConfig {
  id                    String   @id @default("singleton")
  highScoreThreshold    Int      @default(70)   // auto-email threshold
  qualifiedThreshold    Int      @default(50)
  minMonthlyRevenue     Int      @default(10000)
  minTimeInBusinessMos  Int      @default(6)
  updatedAt             DateTime @updatedAt
}

// ─── Workflow automation engine ────────────────────────────────────

enum RunStatus {
  RUNNING
  SUCCESS
  FAILED
  WAITING
}

enum StepStatus {
  PENDING
  RUNNING
  SUCCESS
  FAILED
  SKIPPED
}

model Workflow {
  id          String   @id @default(cuid())
  name        String
  description String?  @db.Text
  enabled     Boolean  @default(true)

  // trigger: { type: 'LEAD_SCORED' | 'LEAD_CREATED' | ..., config: {...} }
  trigger     Json
  // nodes: [{ id, type, position: {x,y}, data: {...config} }, ...]
  nodes       Json
  // edges: [{ id, from, to, condition?, label? }, ...]
  edges       Json

  ownerId     String
  owner       User     @relation(fields: [ownerId], references: [id], onDelete: Cascade)

  runs        WorkflowRun[]

  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@index([ownerId])
  @@index([enabled])
}

model WorkflowRun {
  id          String    @id @default(cuid())
  workflowId  String
  workflow    Workflow  @relation(fields: [workflowId], references: [id], onDelete: Cascade)

  // trigger payload that kicked this off
  triggerData Json
  status      RunStatus @default(RUNNING)

  // optional lead context — most runs are lead-centric
  leadId      String?
  lead        Lead?     @relation(fields: [leadId], references: [id], onDelete: SetNull)

  steps       WorkflowStep[]

  // when a WAIT node parks the run — cron picks these up
  resumeAt    DateTime?
  cursorNode  String?   // node id to resume from

  startedAt   DateTime  @default(now())
  completedAt DateTime?

  @@index([workflowId, startedAt])
  @@index([status])
  @@index([resumeAt])
  @@index([leadId])
}

model WorkflowStep {
  id          String      @id @default(cuid())
  runId       String
  run         WorkflowRun @relation(fields: [runId], references: [id], onDelete: Cascade)

  nodeId      String      // references node.id inside Workflow.nodes
  nodeType    String      // 'SEND_EMAIL', 'WAIT', ...
  label       String?

  input       Json
  output      Json?
  status      StepStatus  @default(PENDING)
  error       String?     @db.Text

  startedAt   DateTime    @default(now())
  completedAt DateTime?

  @@index([runId, startedAt])
  @@index([status])
}
