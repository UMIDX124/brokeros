# ─── Database (Neon) ───────────────────────────────────────────────
# Pooled connection (used by the app at runtime)
DATABASE_URL="postgresql://user:password@ep-xxx-pooler.region.aws.neon.tech/brokeros?sslmode=require"
# Direct connection (used by `prisma migrate`)
DIRECT_URL="postgresql://user:password@ep-xxx.region.aws.neon.tech/brokeros?sslmode=require"

# ─── Auth (NextAuth v5) ────────────────────────────────────────────
# Generate with: openssl rand -base64 32
NEXTAUTH_SECRET="replace-me-with-a-32-byte-random-string"
NEXTAUTH_URL="http://localhost:3000"

# ─── AI (Groq) ─────────────────────────────────────────────────────
GROQ_API_KEY="gsk_..."
GROQ_MODEL="llama-3.3-70b-versatile"

# ─── Email (Resend) ────────────────────────────────────────────────
RESEND_API_KEY="re_..."
RESEND_FROM_EMAIL="onboarding@resend.dev"

# ─── App ───────────────────────────────────────────────────────────
APP_URL="http://localhost:3000"

# ─── Abuse protection (Upstash + Cloudflare Turnstile) ─────────────
# Rate limit on /api/leads — when both unset, limiter is disabled + logs a warning.
UPSTASH_REDIS_REST_URL="https://xxx.upstash.io"
UPSTASH_REDIS_REST_TOKEN="AX..."
# Turnstile — when server key unset, verification is bypassed (demo-safe).
NEXT_PUBLIC_TURNSTILE_SITE_KEY="0x4AAAAAAA..."
TURNSTILE_SECRET_KEY="0x4AAAAAAA..."
